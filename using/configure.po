msgstr "incref ਅਤੇ decref;"

msgid "interpreter incref and decref;"
msgstr "interpreter incref ਅਤੇ decref;"

msgid "allocations: all, 512 bytes, 4 kiB, big;"
msgstr "ਮੈਮੋਰੀ allocations: ਸਾਰੀਆਂ, 512 bytes, 4 kiB, ਵੱਡੀਆਂ;"

